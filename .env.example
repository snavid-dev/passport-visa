# ============================================================
# Iran Visa Processing System — Environment Configuration
# Copy this file to .env and fill in values.
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_HOST=localhost
DB_NAME=sql_passport_vis
DB_USER=sql_passport_vis
DB_PASS=dca957546afa6
DB_CHARSET=utf8mb4

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_URL=https://passport-visa.cyborgtech.co
APP_ENV=production
# Set to development for verbose CI3 error display and logging
# APP_ENV=development

# ------------------------------------------------------------
# GitHub Personal Access Token
# Used by Claude Code to push commits on behalf of snavid-dev.
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (full), workflow
# IMPORTANT: This token authenticates pushes as snavid-dev.
# Claude Code must NEVER commit under its own identity.
# ------------------------------------------------------------
GITHUB_TOKEN=your_github_pat_here

# Remote URL with token (auto-built from above — do not edit)
# git remote set-url origin https://snavid-dev:${GITHUB_TOKEN}@github.com/snavid-dev/passport-visa.git
